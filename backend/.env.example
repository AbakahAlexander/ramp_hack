# App
APP_NAME=Crux API
ENVIRONMENT=development
CORS_ORIGINS=*

# Database — SQLite on the service (hackathon default).
# For durable data on Koyeb, use Koyeb Postgres or Supabase and set:
# DATABASE_URL=postgresql://user:password@host:5432/crux
DATABASE_URL=sqlite:///./crux.db

# Seed demo gym/walls/staff on startup (no routes)
SEED_ON_STARTUP=true
# Wipe all routes on each deploy so the gym starts empty until Add Route
CLEAR_ROUTES_ON_STARTUP=true

# OpenAI — required for AI route insights + image→grid
# Set the real key in a local .env or Koyeb env vars — never commit it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
