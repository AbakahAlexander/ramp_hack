# App
APP_NAME=Crux API
ENVIRONMENT=development
CORS_ORIGINS=*

# Database — SQLite on the service (hackathon default).
# For durable data on Koyeb, use Koyeb Postgres or Supabase and set:
# DATABASE_URL=postgresql://user:password@host:5432/crux
DATABASE_URL=sqlite:///./crux.db

# Seed demo data on startup
SEED_ON_STARTUP=true
